generator client {
  provider = "prisma-client"
  output   = "../packages/server/src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Node {
  id              String           @id @default(cuid())
  name            String           @unique
  ipAddress       String?
  // Optional fast-fabric IP (e.g. 192.168.100.x) used for bulk node↔node
  // transfers like image sync. Falls back to ipAddress when null.
  fastIpAddress   String?
  agentPort       Int              @default(8089)
  status          String           @default("new")
  provisionStatus String           @default("pending")
  provisionLog    String?
  gpuModel        String?
  vramTotal       Int?
  dockerAvailable Boolean          @default(false)
  ollamaInstalled Boolean          @default(false)
  agentVersion    String?
  arch            String?
  // Deliberate power intent, distinct from agent-connection `status`.
  // Values: "on" | "rebooting" | "off" | "waking" | "asleep".
  powerState      String           @default("on")
  // MAC of the interface bound to ipAddress, captured over SSH while the node
  // is reachable. Required for Wake-on-LAN. Null until first captured.
  macAddress      String?
  bootstrapMethod String           @default("ssh")
  lastSeen        DateTime?
  createdAt       DateTime         @default(now())
  deployments              Deployment[]
  clusterMemberships       ClusterNode[]
  finetuneJobs             FineTuneJob[]
  finetuneClusterMemberships FineTuneClusterNode[]
  metrics                  MetricSnapshot[]
}

model JoinToken {
  id           String    @id @default(cuid())
  token        String    @unique
  label        String?
  expiresAt    DateTime?
  usedAt       DateTime?
  usedByNodeId String?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
}

model Setting {
  key   String @id
  value String
}

model Model {
  id          String       @id @default(cuid())
  name        String       @unique
  runtime     String
  parameters  String?
  // FK to the FineTuneJob this Model row represents. Null for non-finetune
  // models (hand-created, Ollama, etc.). Enables (a) cascade-delete so a
  // deleted job doesn't leave orphan Model rows in the deployable list,
  // and (b) explicit linkage instead of name-prefix string magic.
  finetuneJobId String?      @unique
  finetuneJob   FineTuneJob? @relation(fields: [finetuneJobId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  deployments Deployment[]
}

model Deployment {
  id           String                 @id @default(cuid())
  // User-supplied friendly name. When set, it overrides `model.name` in the
  // dashboard list AND is passed to vLLM as `--served-model-name`, so the
  // deployment surfaces under this name in OpenAI-API responses
  // (`/v1/models` and the `model` field of completions). Null falls back to
  // `model.name`. Normalized and uniqueness-validated at the route layer
  // (src/deployments/display-name.ts) — null entries skip the uniqueness
  // check so unnamed deployments coexist freely.
  displayName  String?
  nodeId       String
  modelId      String
  status       String                 @default("pending")
  port         Int?
  config       String?
  clusterMode  Boolean                @default(false)
  vramEstimate Int?
  vramActual   Int?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  node         Node                   @relation(fields: [nodeId], references: [id])
  model        Model                  @relation(fields: [modelId], references: [id])
  lbEndpoints   LoadBalancerEndpoint[]
  clusterNodes  ClusterNode[]
  benchmarkRuns BenchmarkRun[]
}

model ClusterNode {
  id           String     @id @default(cuid())
  deploymentId String
  nodeId       String
  role         String     @default("worker")
  status       String     @default("pending")
  deployment   Deployment @relation(fields: [deploymentId], references: [id])
  node         Node       @relation(fields: [nodeId], references: [id])
}

model MetricSnapshot {
  id             String   @id @default(cuid())
  nodeId         String
  gpuUtil        Float
  vramUsed       Int
  tps            Float?
  activeRequests Int?
  temperature    Float?
  // Unified-memory + PSI, added 2026-05-09 to diagnose soft-hangs at
  // end-of-training where the GB10's shared GPU+CPU pool gets exhausted
  // and the kernel can't allocate even small new pages.
  // All nullable for backwards compat with pre-extension agents.
  memTotalMb          Int?
  memAvailableMb      Int?
  memCachedMb         Int?
  swapTotalMb         Int?
  swapUsedMb          Int?
  pressureMemoryAvg10 Float?
  pressureIoAvg10     Float?
  pressureCpuAvg10    Float?
  timestamp      DateTime @default(now())
  node           Node     @relation(fields: [nodeId], references: [id])

  @@index([nodeId, timestamp(sort: Desc)])
}

model LoadBalancerRule {
  id         String                 @id @default(cuid())
  name       String                 @unique
  modelName  String
  strategy   String                 @default("round-robin")
  listenPath String                 @default("/v1")
  createdAt  DateTime               @default(now())
  endpoints  LoadBalancerEndpoint[]
}

model LoadBalancerEndpoint {
  id           String           @id @default(cuid())
  ruleId       String
  deploymentId String
  weight       Int              @default(1)
  rule         LoadBalancerRule @relation(fields: [ruleId], references: [id])
  deployment   Deployment       @relation(fields: [deploymentId], references: [id])
}

model FineTuneJob {
  id           String    @id @default(cuid())
  nodeId       String
  // User-facing name for the fine-tune. Settable at creation and via PATCH.
  // When null, the dashboard falls back to a derived label (recipe name +
  // job-id prefix). Mirrors into the associated Model.name on deploy so the
  // deployable-models list shows the user's chosen label.
  displayName  String?
  recipeFile   String?
  baseModel    String
  method       String
  dataset      String
  config       String?
  status       String    @default("pending")
  progress     Float?
  outputDir    String?
  outputPath   String?
  mergeStatus          String?
  mergedPath           String?
  // FP8 quantization (post-merge). Defaults to null until POST /api/finetune/:id/quantize
  // fires; transitions to "quantizing"→"quantized"|"failed". Independent of mergeStatus so
  // the BF16 deploy path can ignore it entirely.
  quantizationStatus   String?   // null | "pending" | "quantizing" | "quantized" | "failed"
  quantizedPath        String?
  quantizationLog      String?
  quantizedAt          DateTime?
  deploymentId         String?
  logs         String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  node         Node      @relation(fields: [nodeId], references: [id])
  model        Model?
  metrics      TrainingMetric[]
  // For multi-node runs, one row per participating node (head + workers).
  // Single-node runs leave this empty; the head can be inferred from
  // `nodeId`. Mirrors the ClusterNode pattern used by Deployment.
  clusterNodes FineTuneClusterNode[]
}

model FineTuneClusterNode {
  id        String      @id @default(cuid())
  jobId     String
  nodeId    String
  role      String      @default("worker")
  createdAt DateTime    @default(now())
  job       FineTuneJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  node      Node        @relation(fields: [nodeId], references: [id])

  @@unique([jobId, nodeId])
  @@index([jobId])
}

model Dataset {
  id            String   @id @default(cuid())
  name          String
  description   String?
  format        String   @default("jsonl")
  source        String   @default("upload")
  path          String?
  huggingfaceId String?
  size          Int?
  sampleCount   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TrainingMetric {
  id        String   @id @default(cuid())
  jobId     String
  step      Int
  loss      Float
  lr        Float?
  evalLoss  Float?
  timestamp DateTime @default(now())
  job       FineTuneJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, step])
  @@index([jobId, step])
}

model BenchmarkRun {
  id              String   @id @default(cuid())
  // Nullable + onDelete:SetNull so deleting a deployment doesn't erase its
  // benchmark history — runs are a permanent record we want to keep for
  // before/after comparisons.
  deploymentId    String?
  presetId        String?  // null when the run used a fully custom config
  // Snapshot of the target at run-time. We keep these locally so the row
  // remains interpretable after the deployment is gone.
  modelName       String
  endpointUrl     String
  servedModelName String
  // JSON-encoded BenchmarkConfig (pp, tg, depth, runs, concurrency, etc.)
  config          String
  status          String   @default("pending") // pending | running | completed | failed | canceled
  // Which benchmark family this run belongs to. "throughput" = llama-benchy
  // (pp/tg/depth/concurrency -> TPS/TTFR rows). "tool-eval" = tool-eval-bench
  // (tool-calling accuracy -> a score + per-category breakdown).
  kind            String   @default("throughput") // throughput | tool-eval
  error           String?
  startedAt       DateTime?
  completedAt     DateTime?
  // Raw result payload from the benchmark CLI: llama-benchy JSON for throughput
  // runs, the tool-eval-bench --json payload for tool-eval runs. Kept as the
  // source of truth / fallback if structured parsing fails.
  rawOutput       String?
  // Aggregate stats surfaced in list/compare views so we don't recompute on
  // every page render.
  meanTps         Float?
  meanTtfrMs      Float?
  // --- tool-eval-bench headline metrics (null on throughput runs) ---
  toolEvalScore          Float?  // scores.final_score, 0-100
  toolEvalRating         String? // rating star string, e.g. "★★★ Adequate"
  toolEvalDeployability  Int?    // deployability
  toolEvalResponsiveness Int?    // responsiveness (small star-style int, NOT 0-100)
  toolEvalTotalScenarios Int?    // total_scenarios
  toolEvalTotalPoints    Int?    // scores.total_points
  toolEvalMaxPoints      Int?    // scores.max_points
  toolEvalSafetyWarnings String? // JSON-encoded string[] (safety_warnings)
  createdAt       DateTime @default(now())
  deployment      Deployment? @relation(fields: [deploymentId], references: [id], onDelete: SetNull)
  results         BenchmarkResult[]
  toolEvalCategories ToolEvalCategory[]

  @@index([deploymentId, createdAt])
  @@index([status])
}

model BenchmarkResult {
  id          String   @id @default(cuid())
  runId       String
  // What kind of measurement this row represents: "pp" (prompt processing /
  // prefill) or "tg" (token generation / decode). Lets us bucket charts.
  opType      String
  pp          Int
  tg          Int
  depth       Int
  concurrency Int      @default(1)
  tps         Float
  peakTps     Float?
  ttfrMs      Float?
  estPptMs    Float?
  e2eTtftMs   Float?
  // Standard deviations from multi-run averaging — null when --runs=1.
  tpsStdev    Float?
  ttfrStdev   Float?
  run         BenchmarkRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}

model ToolEvalCategory {
  id           String @id @default(cuid())
  runId        String
  // From scores.category_scores[] in the tool-eval-bench JSON.
  code         String // category, e.g. "A"
  label        String // e.g. "Tool Selection"
  percent      Float  // 0-100
  earned       Int
  maxPoints    Int    // category_scores[].max
  passCount    Int
  partialCount Int
  failCount    Int
  run          BenchmarkRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
}
