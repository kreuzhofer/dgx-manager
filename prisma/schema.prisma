generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DgxNode {
  id        String   @id @default(cuid())
  name      String
  host      String   @unique
  status    String   @default("unknown")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
