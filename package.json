{
  "name": "dgx-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/server & npm run dev --workspace=packages/dashboard & wait",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev:dashboard": "npm run dev --workspace=packages/dashboard",
    "build": "npm run build --workspaces",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.5.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  }
}
